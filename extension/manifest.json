{
  "manifest_version": 3,
  "name": "Houdini (internal study)",
  "version": "0.4.10",
  "minimum_chrome_version": "111",
  "description": "Internal study only. Records your AI web-chat prompts/replies LOCALLY to the Houdini app. No data leaves your machine.",
  "author": "Rahul Biliyar <rahul@memfold.ai>",
  "homepage_url": "https://github.com/memfoldai/houdini",
  "key": "",
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "permissions": ["nativeMessaging"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*"
      ],
      "js": ["capture.js"],
      "run_at": "document_idle"
    }
  ]
}
