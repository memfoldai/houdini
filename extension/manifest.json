{
  "manifest_version": 3,
  "name": "AI Usage Monitor (internal study)",
  "version": "0.4.5",
  "minimum_chrome_version": "111",
  "description": "Internal study only. Records your AI web-chat prompts/replies LOCALLY to the AI Usage Monitor app. No data leaves your machine.",
  "homepage_url": "https://github.com/memfoldai/ai-usage-monitor",
  "key": "",
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "permissions": ["nativeMessaging"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["relay.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
