<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Minimal entitlements for the internal, self-signed build.
    - No App Sandbox: the app reads AI tools' transcript files under $HOME and
      enumerates its own processes' sockets via libproc, which the sandbox would
      restrict. It requests NO TCC grant (no Screen Recording, no Accessibility)
      and holds no NetworkExtension entitlement — socket enumeration is
      unprivileged, own-user only.
    - Allow unsigned executable memory / JIT are intentionally absent.
    This file only sets the hardened-runtime shape.
  -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <false/>
</dict>
</plist>
